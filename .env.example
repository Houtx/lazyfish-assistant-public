# Stable public image. Installers keep `latest` so rerunning them performs an update.
APP_IMAGE=ghcr.io/houtx/lazyfish-assistant-public
IMAGE_TAG=latest
APP_BIND_HOST=127.0.0.1
APP_PORT=9000
TZ=Asia/Shanghai

# Public product identity shown in the application and support links.
PRODUCT_ID=lazyfish-assistant
PRODUCT_NAME=懒鱼助手
PRODUCT_SHORT_NAME=懒鱼
PRODUCT_TAGLINE=二手电商运营管理工具
PRODUCT_LOGO_URL=/static/brand-logo.svg
PRODUCT_VENDOR=独立软件发行版
PRODUCT_SUPPORT_URL=https://lazyfish.haoyunqiankun.com/
PRODUCT_SUPPORT_EMAIL=
PRODUCT_SOURCE_URL=https://github.com/Houtx/lazyfish-assistant-public/blob/main/SOURCE.md

# Leave empty to let the application generate the first-login admin password.
# The login page displays it until the administrator sets a new password.
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_PASSWORD_FILE=
SEND_MESSAGE_API_KEY=
SEND_MESSAGE_API_KEY_FILE=

# Optional fixed Fernet key for managed deployments. Generate with:
# openssl rand -base64 32
# Never change this after encrypted data has been written. Back it up separately.
SECRET_ENCRYPTION_KEY=

# Commercial license. Customers only receive the public key in the image.
# LICENSE_SERVER_URL must be your public HTTPS /v1/check endpoint.
LICENSE_REQUIRED=true
LICENSE_SERVER_URL=https://license.haoyunqiankun.com/v1/check
LICENSE_KEY=
LICENSE_REFRESH_SECONDS=900
LICENSE_OFFLINE_GRACE_SECONDS=3600

# Remote captcha control is disabled unless both settings are explicitly configured.
CAPTCHA_REMOTE_ENABLED=false
CAPTCHA_REMOTE_TOKEN=

# Outbound HTTP defaults to public HTTPS only. Add exact administrator-approved
# origins only when an integration must use HTTP or a private address. Paths do
# not belong here. Example for a local Ollama service:
# OUTBOUND_ALLOWED_ORIGINS=http://host.docker.internal:11434
OUTBOUND_ALLOWED_ORIGINS=

# Optional HTTPS-only card-delivery integration. Empty values keep it disconnected.
YIFAN_API_URL=
YIFAN_CALLBACK_URL=
YIFAN_QUERY_URL=

# Signed update checks are read-only and disabled by default.
SIGNED_UPDATE_CHECK_ENABLED=false
UPDATE_CHANNEL=stable
UPDATE_MANIFEST_URL=
UPDATE_SIGNATURE_URL=

# Runtime and retention tuning.
LOG_LEVEL=INFO
SQL_LOG_ENABLED=false
SQL_LOG_LEVEL=INFO
BACKUP_RETENTION_DAYS=7
LOG_RETENTION_DAYS=7
SLIDER_DEBUG_RETENTION_DAYS=7
MAINTENANCE_CHECK_INTERVAL=3600
SHM_SIZE=1gb
CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILES=3

# Secure noVNC manual takeover. Installers create this password file locally.
VNC_PASSWORD_FILE=./secrets/vnc_password.txt
NOVNC_PORT=6080
MANUAL_VERIFICATION_URL=http://127.0.0.1:6080/vnc.html?autoconnect=1&resize=scale
XY_MANUAL_SLIDER_TAKEOVER_TIMEOUT=450
